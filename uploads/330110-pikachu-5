(function () {
  var ua = navigator.userAgent.toLowerCase();
  var cookieName = 'hide_android_banner';

  function hasCookie(name) {
    return document.cookie.indexOf(name + '=1') !== -1;
  }

  function setCookie(name, hours) {
    var d = new Date();
    d.setTime(d.getTime() + hours * 60 * 60 * 1000);
    document.cookie = name + '=1; expires=' + d.toUTCString() + '; path=/';
  }

  var isAndroid = ua.indexOf('android') !== -1;
  var isBrowser = /(chrome|firefox|safari|edge|opera)/.test(ua);
  var isWebView = /(wv|webview|fbav|instagram|twitter|discord)/.test(ua);

  if (isAndroid && isBrowser && !isWebView && !hasCookie(cookieName)) {
    var banner = document.getElementById('android');
    var close  = document.getElementById('android-close');

    banner.style.display = 'block';

    close.onclick = function () {
      banner.style.display = 'none';
      setCookie(cookieName, 12); // 12 hours
    };
  }
})();


</script>
